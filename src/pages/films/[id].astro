---
import Layout from "../../layouts/Layout.astro";
import FilmSign from "../../components/FilmSign.astro";
import films from "../../data/films.json";
import imdbapi from "../../data/imdbapi.json";

export async function getStaticPaths() {
  const filmsSortedByRating = films.sort((a, b) => b.rating - a.rating);
  const filmsWatchedThenUnwatched = filmsSortedByRating
    ?.filter((f) => f.watched)
    .concat(filmsSortedByRating?.filter((f) => !f.watched));

  return filmsWatchedThenUnwatched.map((f) => {
    return {
      params: { id: f.id },
      props: { film: { ...f }, filmImdb: imdbapi.find((r) => r.id === f.id) },
    };
  });
}

const { film, filmImdb } = Astro.props;
---

<Layout>
  <div
    id="back"
    class="fixed z-2 min-h-screen size-full flex items-center justify-center"
  >
    <div class="flex space-x-16 w-11/12 2xl:w-5/6 items-center justify-center">
      <div class="lg:flex-2/3 p-1 lg:p-16">
        <div
          class="bg-amber-100 text-red-950 font-[Limelight] px-4 lg:px-8 py-16"
          style="filter: drop-shadow(0 5px 5px #000)"
        >
          <h1
            class="text-2xl lg:text-6xl text-center mb-4 flex items-center justify-center space-x-4"
          >
            <span>★</span>
            <span>
              {film.title}
            </span>
            <span>★</span>
          </h1>
          <h2 class="lg:text-2xl">
            Release year: {filmImdb?.startYear}
          </h2>
          <h2 class="lg:text-2xl">
            IMDb Rating: {filmImdb?.rating.aggregateRating} / 10
          </h2>
          <p class="lg:text-xl indent-8 mt-8 mx-8">
            The Truman Show is a tear-shedding intrepretation of Plato's
            Allegory of the Cave. Jim Carrey manages to find the perfect blend
            of comedic and serious in his acting. As Truman's sense of reality
            slowly and painfully shatters, the viewer can't help but feel
            themselves in his shoes.
          </p>
        </div>
      </div>
      <div class="flex-1/3 hidden lg:block" transition:animate="slide">
        {
          film && (
            <FilmSign
              id={film.id}
              ranking={Astro.url.searchParams.get("r") || undefined}
              title={film.title}
              rating={film.rating}
              watched={film.watched}
            />
          )
        }
      </div>
    </div>
  </div>
</Layout>
<main
  class="min-h-screen overflow-hidden p-2 pb-32 md:p-4 md:pt-5 md:pb-64 bg-[url(/red-wall.png)] bg-linear-to-l from-red-900 to-red-500"
>
</main>

<script is:inline data-astro-rerun>
  var back = document.getElementById("back");
  back?.addEventListener("click", () => {
    history.back();
  });
</script>
