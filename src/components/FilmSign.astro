---
import imdbResults from "../data/imdbapi.json";
import StarRating from "../components/StarRating.astro";

const { id, ranking, title, rating, watched } = Astro.props;

const posterUrl = imdbResults.find((r) => r?.id === id)?.primaryImage?.url;

const signId = `sign-${id}`;
const lightsId = `sign-${id}-lights`;
//NOTE transition:name will falsely throw a non-unique name error if linked to a <inline><block/></inline> structure on Firefox
//     the fix is to make the inline element (in this case, <a>) display as a block
//     see: https://bugzilla.mozilla.org/show_bug.cgi?id=1999336
---

<div
  id={signId}
  class="relative p-1.5 bg-stone-800 group hover:shadow-xl/100 shadow-yellow-100 transition duration-300 ease-in-out"
  style="filter: drop-shadow(0 5px 5px #000)"
>
  <div class="p-0.5 bg-olive-700 group-hover:bg-yellow-400">
    <div class="p-1.5 bg-stone-800">
      <!--:style="[ watched ? 'filter: drop-shadow(0 1px 1px #000); animation-name: pulse; animation-duration: 20s; animation-iteration-count: infinite;' : 'filter: drop-shadow(0 1px 1px #000);', ]"-->
      <div class="bg-yellow-100 text-red-950 font-[Limelight]">
        <div
          class="relative after:absolute after:inset-0 after:block after:inset-shadow-sm after:inset-shadow-black"
        >
          {
            posterUrl ? (
              <img
                src={posterUrl}
                class="object-cover aspect-68/100"
                loading="lazy"
              />
            ) : (
              <div class="aspect-68/100 select-none flex items-center justify-center text-center text-sm md:text-xl">
                {title}
              </div>
            )
          }
          <div class="z-1 absolute w-2/3 bottom-0 right-10 translate-1/2">
            <StarRating
              rating={rating}
              watched={watched}
              class="select-none group-hover:opacity-5 transition duration-300 ease-in-out"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
  {
    ranking && (
      <div class="absolute bottom-0 left-0 translate-y-1/1 bg-yellow-50 py-1 px-3 rounded-b-xl font-[Limelight]">
        #{ranking}
      </div>
    )
  }
</div>

