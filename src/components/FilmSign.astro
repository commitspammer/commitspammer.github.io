    border-image-source: url("../assets/yellow-led-on.svg");
  }
  .leds-off {
    border-image-slice: 33.33%;
    border-image-repeat: space;
    border-image-source: url("../assets/yellow-led-off.svg");
  }
  @keyframes pulse {
    0%,
    94%,
    97% {
      border-image-source: url("../assets/yellow-led-off.svg");
    }
    95%,
    99% {
      border-image-source: url("../assets/yellow-led-on.svg");
    }
    }*/
</style>

