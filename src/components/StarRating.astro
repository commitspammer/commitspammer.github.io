---
import PlainStar from "../assets/star.svg";

const { rating, watched, class: className } = Astro.props;
---

<div class:list={["relative flex items-center justify-center", className]}>
  { watched ? (
    <PlainStar class="fill-yellow-400 stroke-yellow-100 stroke-[0.5]" />
    <div class="absolute z-1 inset-0 flex items-center justify-center">
      {rating}
    </div>
  ) : (
    <PlainStar class="fill-red-950 stroke-orange-900 stroke-[0.5]" />
    <div class="absolute z-1 inset-0 flex items-center justify-center text-white">
      ?
    </div>
  ) }
</div>
