---
import Star from "../assets/star.svg";

const { rating, watched, class: className } = Astro.props;
//"size-20 md:size-32 text-2xl md:text-4xl"
---

<div class:list={["relative flex items-center justify-center bigcum", className]}>
  { watched ? (
    <Star class="fill-yellow-400 stroke-yellow-100 stroke-[0.5]" />
    <div class="absolute z-1 inset-0 flex items-center justify-center littlecum">
      {rating}
    </div>
  ) : (
    <Star class="fill-red-950 stroke-orange-900 stroke-[0.5]" />
    <div class="absolute z-1 inset-0 flex items-center justify-center text-white littlecum">
      ?
    </div>
  ) }
</div>

<style>
.bigcum {
  container-type: inline-size;
}
.littlecum {
  font-size: clamp(1rem, 28cqw, 9001rem);
}
</style>
